---
interface Props {
  title: string;
  subtitle: string;
  highlight?: string;
  primaryCta?: {
    text: string;
    href: string;
  };
  secondaryCta?: {
    text: string;
    href: string;
  };
}

const { title, subtitle, highlight, primaryCta, secondaryCta } = Astro.props;
---

<section class="relative min-h-[90vh] flex items-center gradient-hero overflow-hidden">
  <!-- Animated background elements -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-20 left-10 w-64 h-64 bg-white/5 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent-500/10 rounded-full blur-3xl animate-float" style="animation-delay: -3s;"></div>
    <div class="absolute top-1/2 left-1/2 w-80 h-80 bg-primary-300/10 rounded-full blur-3xl animate-float" style="animation-delay: -1.5s;"></div>
  </div>

  <div class="container-main relative z-10 py-20">
    <div class="max-w-3xl animate-fade-in">
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-white mb-6 leading-tight sm:whitespace-nowrap">
        {title}
      </h1>
      <p class="text-xl md:text-2xl text-primary-100 mb-4 leading-relaxed">
        {subtitle}
      </p>
      {highlight && (
        <p class="text-lg md:text-xl text-accent-300 font-medium mb-8">
          {highlight}
        </p>
      )}
      
      {(primaryCta || secondaryCta) && (
        <div class="flex flex-wrap gap-4">
          {primaryCta && (
            <a href={primaryCta.href} class="btn btn-accent">
              {primaryCta.text}
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          )}
          {secondaryCta && (
            <a href={secondaryCta.href} class="btn bg-white/10 text-white border-2 border-white/30 hover:bg-white/20">
              {secondaryCta.text}
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-surface-50 dark:from-surface-950 to-transparent"></div>
</section>
