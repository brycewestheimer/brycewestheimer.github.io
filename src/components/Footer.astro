---
const currentYear = new Date().getFullYear();

const socialLinks = [
  { 
    href: 'https://github.com/brycewestheimer', 
    label: 'GitHub',
    icon: 'github'
  },
  { 
    href: 'https://linkedin.com/in/brycewestheimer', 
    label: 'LinkedIn',
    icon: 'linkedin'
  },
  { 
    href: 'https://scholar.google.com/citations?user=brycewestheimer', 
    label: 'Google Scholar',
    icon: 'scholar'
  },
];

const footerLinks = [
  { href: '/about', label: 'About' },
  { href: '/publications', label: 'Publications' },
  { href: '/projects', label: 'Projects' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="bg-surface-100 dark:bg-surface-900 border-t border-surface-200 dark:border-surface-800">
  <div class="container-main py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="text-xl font-bold text-primary-700 dark:text-primary-300">
          Bryce M. Westheimer
        </a>
        <p class="mt-2 text-sm text-surface-600 dark:text-surface-400">
          Scientific Software Developer & Researcher specializing in computational chemistry and high-performance computing.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold text-surface-900 dark:text-surface-100 uppercase tracking-wider mb-4">
          Quick Links
        </h3>
        <ul class="space-y-2">
          {footerLinks.map((link) => (
            <li>
              <a 
                href={link.href}
                class="text-sm text-surface-600 hover:text-primary-600 dark:text-surface-400 dark:hover:text-primary-300 transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social Links -->
      <div>
        <h3 class="text-sm font-semibold text-surface-900 dark:text-surface-100 uppercase tracking-wider mb-4">
          Connect
        </h3>
        <div class="flex gap-4">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              class="p-2 rounded-md text-surface-600 hover:text-primary-600 hover:bg-surface-200 dark:text-surface-400 dark:hover:text-primary-300 dark:hover:bg-surface-800 transition-colors"
            >
              {social.icon === 'github' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                </svg>
              )}
              {social.icon === 'linkedin' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              )}
              {social.icon === 'scholar' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-8 pt-8 border-t border-surface-200 dark:border-surface-800">
      <p class="text-center text-sm text-surface-500 dark:text-surface-500">
        © {currentYear} Bryce M. Westheimer. All rights reserved.
      </p>
    </div>
  </div>
</footer>
