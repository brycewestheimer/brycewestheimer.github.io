---
interface Props {
  title: string;
  description: string;
  techs?: string[];
  status?: 'Active' | 'Preview' | 'Development';
  href?: string;
  github?: string;
}

const { title, description, techs = [], status, href, github } = Astro.props;

const statusClasses = {
  Active: 'badge-active',
  Preview: 'badge-preview',
  Development: 'badge-development',
};
---

<article class="card group">
  <div class="flex items-start justify-between mb-4">
    <h3 class="text-lg font-semibold text-surface-900 dark:text-surface-100 group-hover:text-primary-600 dark:group-hover:text-primary-300 transition-colors">
      {title}
    </h3>
    {status && (
      <span class={`tag ${statusClasses[status]}`}>
        {status}
      </span>
    )}
  </div>
  
  <p class="text-surface-600 dark:text-surface-400 text-sm mb-4 line-clamp-3">
    {description}
  </p>

  {techs.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-4">
      {techs.map((tech) => (
        <span class="tag">{tech}</span>
      ))}
    </div>
  )}

  <div class="flex gap-3 mt-auto pt-4 border-t border-surface-200 dark:border-surface-800">
    {href && (
      <a 
        href={href} 
        class="text-sm font-medium text-primary-600 hover:text-primary-500 dark:text-primary-400 dark:hover:text-primary-300 transition-colors flex items-center gap-1"
      >
        View Project
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    )}
    {github && (
      <a 
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-surface-600 hover:text-surface-900 dark:text-surface-400 dark:hover:text-surface-200 transition-colors flex items-center gap-1"
      >
        GitHub
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
      </a>
    )}
  </div>
</article>
