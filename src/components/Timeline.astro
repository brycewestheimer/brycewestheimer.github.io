---
interface TimelineItem {
  year: string;
  title: string;
  organization: string;
  description?: string;
}

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;
---

<div class="relative">
  <!-- Vertical line -->
  <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-primary-200 dark:bg-primary-800"></div>

  <div class="space-y-8">
    {items.map((item, index) => (
      <div class="relative pl-12 animate-fade-in" style={`animation-delay: ${index * 100}ms`}>
        <!-- Circle marker -->
        <div class="absolute left-2.5 top-1.5 w-3 h-3 rounded-full bg-primary-500 dark:bg-primary-400 ring-4 ring-surface-50 dark:ring-surface-950"></div>
        
        <!-- Year badge -->
        <span class="inline-block mb-2 text-sm font-semibold text-primary-600 dark:text-primary-400">
          {item.year}
        </span>

        <!-- Content -->
        <h3 class="text-lg font-semibold text-surface-900 dark:text-surface-100">
          {item.title}
        </h3>
        <p class="text-sm text-primary-600 dark:text-primary-300 font-medium">
          {item.organization}
        </p>
        {item.description && (
          <p class="mt-2 text-sm text-surface-600 dark:text-surface-400">
            {item.description}
          </p>
        )}
      </div>
    ))}
  </div>
</div>
