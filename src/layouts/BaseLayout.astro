---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Scientific Software Developer & Researcher" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Bryce M. Westheimer, PhD" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    
    <!-- Styles -->
    <link rel="stylesheet" href="/src/styles/global.css" />
    
    <title>{title} | Bryce M. Westheimer</title>
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <slot name="header" />
    
    <main class="flex-1">
      <slot />
    </main>
    
    <slot name="footer" />
    
    <!-- Dark mode script (runs before page renders to avoid flash) -->
    <script is:inline>
      const theme = localStorage.getItem('theme') || 
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>
  </body>
</html>
