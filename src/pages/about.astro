---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Timeline from '../components/Timeline.astro';
import SkillsGrid from '../components/SkillsGrid.astro';

const careerTimeline = [
  {
    year: "2024 – Present",
    title: "Postdoctoral Fellow",
    organization: "University of Colorado Denver",
    description: "Leading method development for multi-layer adaptive partitioning (MAP) and accelerator-aware electronic structure workflows."
  },
  {
    year: "2022 – 2024",
    title: "Postdoctoral Research Associate",
    organization: "Ames National Laboratory",
    description: "Advanced extreme-scale GAMESS development for heterogeneous supercomputing architectures."
  },
  {
    year: "2015 – 2022",
    title: "Graduate Research Assistant",
    organization: "Gordon Group, Iowa State University",
    description: "Developed treatments of interfragment covalent bonds, scalable Non-orthogonal MO expansions, and contributed to GAMESS."
  },
  {
    year: "2014 – 2015",
    title: "Undergraduate Researcher",
    organization: "Prody Lab, Western Washington University",
    description: "Built computational pipelines for structural biology and spectroscopy projects."
  }
];

const education = [
  {
    year: "2022",
    title: "Ph.D., Physical Chemistry",
    organization: "Iowa State University",
    description: "Dissertation: Developments in fragment-based quantum chemistry: Flattening the curve (advisor: Mark S. Gordon)"
  },
  {
    year: "2015",
    title: "B.S., Chemistry",
    organization: "Western Washington University"
  },
  {
    year: "2012",
    title: "A.S., Chemistry",
    organization: "Clark College"
  }
];

const skillCategories = [
  {
    category: "Quantum Chemistry",
    skills: [
      { name: "Fragment-based methods" },
      { name: "MAP" },
      { name: "QM/MM" },
      { name: "SAPT" },
      { name: "EFP" },
      { name: "DFT" }
    ]
  },
  {
    category: "High-Performance Computing",
    skills: [
      { name: "MPI" },
      { name: "OpenMP" },
      { name: "CUDA" },
      { name: "GPU Acceleration" },
      { name: "Performance Engineering" }
    ]
  },
  {
    category: "Programming Languages",
    skills: [
      { name: "Rust" },
      { name: "Fortran" },
      { name: "C++" },
      { name: "Python" },
      { name: "CUDA" }
    ]
  },
  {
    category: "Tools & Frameworks",
    skills: [
      { name: "CMake" },
      { name: "Git" },
      { name: "CI/CD" },
      { name: "NumPy" },
      { name: "SciPy" }
    ]
  },
  {
    category: "Software Development",
    skills: [
      { name: "GAMESS" },
      { name: "libfrag" },
      { name: "RCChem" },
      { name: "Scientific Python" }
    ]
  },
  {
    category: "Research Skills",
    skills: [
      { name: "Method Development" },
      { name: "Benchmarking" },
      { name: "Technical Writing" },
      { name: "Mentoring" }
    ]
  }
];

const awards = [
  "MolSSI Software Investment Fellow (2020–2021)",
  "Klaus Ruedenberg Theoretical Chemistry Award",
  "Witiak Graduate Fellowship",
  "Alpha Chi Sigma Research Award",
  "Research and Creative Opportunities Award"
];
---

<BaseLayout title="About" description="Learn more about Bryce M. Westheimer's background, experience, and research interests">
  <Header slot="header" />

  <!-- Page Header -->
  <section class="pt-28 pb-12 bg-surface-100 dark:bg-surface-900">
    <div class="container-main">
      <h1 class="text-4xl font-bold text-surface-900 dark:text-surface-100 mb-4">About Me</h1>
      <p class="text-xl text-surface-600 dark:text-surface-400 max-w-3xl">
        Theoretical and computational chemist focused on fragment-based <em>ab initio</em> methods and 
        the high-performance computing software that makes them practical at scale.
      </p>
    </div>
  </section>

  <!-- Bio Section -->
  <section class="py-16">
    <div class="container-main">
      <div class="max-w-3xl space-y-4">
          <p class="text-lg leading-relaxed text-surface-700 dark:text-surface-300">
            I currently split my time between quantum chemistry theory, GPU-ready implementations, 
            and collaborative projects that translate academic advances into tools research labs can deploy.
          </p>
          <p class="text-lg leading-relaxed text-surface-700 dark:text-surface-300">
            As a Postdoctoral Fellow at the University of Colorado Denver, I'm co-advised by 
            Professors Emilie Guidez and Hai Lin, leading method development for multi-layer 
            adaptive partitioning (MAP) and accelerator-aware electronic structure workflows.
          </p>
          <p class="text-lg leading-relaxed text-surface-700 dark:text-surface-300">
            Open science and mentorship are core to my work. I maintain public repositories 
            whenever possible, support early-career researchers adopting GAMESS-derived tooling, 
            and enjoy collaborating with interdisciplinary teams across chemistry, applied math, 
            and computer science.
          </p>
      </div>
    </div>
  </section>

  <!-- Career Timeline -->
  <section class="py-16 bg-surface-100 dark:bg-surface-900">
    <div class="container-main">
      <h2 class="section-title mb-8">Career Journey</h2>
      <div class="max-w-2xl">
        <Timeline items={careerTimeline} />
      </div>
    </div>
  </section>

  <!-- Education -->
  <section class="py-16">
    <div class="container-main">
      <h2 class="section-title mb-8">Education</h2>
      <div class="max-w-2xl">
        <Timeline items={education} />
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="py-16 bg-surface-100 dark:bg-surface-900">
    <div class="container-main">
      <h2 class="section-title mb-8">Technical Expertise</h2>
      <SkillsGrid categories={skillCategories} />
    </div>
  </section>

  <!-- Awards -->
  <section class="py-16">
    <div class="container-main">
      <h2 class="section-title mb-8">Recognition & Awards</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {awards.map((award) => (
          <div class="card flex items-center gap-3">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent-100 dark:bg-accent-900 flex items-center justify-center">
              <svg class="w-5 h-5 text-accent-600 dark:text-accent-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            </div>
            <span class="text-sm font-medium text-surface-700 dark:text-surface-300">{award}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary-600 dark:bg-primary-800">
    <div class="container-main text-center">
      <div class="inline-block mb-4 px-4 py-2 bg-accent-500 text-white text-sm font-semibold rounded-full">
        Open to New Opportunities
      </div>
      <h2 class="text-2xl font-bold text-white mb-4">Let's Connect</h2>
      <p class="text-primary-100 mb-6 max-w-xl mx-auto">
        I'm actively exploring positions in industry, national laboratories, and academia. 
        If you're looking for expertise in computational chemistry, HPC, or scientific software development, let's talk.
      </p>
      <a href="/contact" class="btn btn-accent">
        Get in Touch
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
