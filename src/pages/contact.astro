---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const contactMethods = [
  {
    title: "Email",
    description: "Best for formal inquiries and collaboration requests",
    icon: "email",
    href: "mailto:brycemwestheimer@gmail.com",
    label: "brycemwestheimer@gmail.com"
  },
  {
    title: "GitHub",
    description: "Open issues, PRs, or discuss technical topics",
    icon: "github",
    href: "https://github.com/brycewestheimer",
    label: "@brycewestheimer"
  },
  {
    title: "LinkedIn",
    description: "Professional networking and career opportunities",
    icon: "linkedin",
    href: "https://linkedin.com/in/brycewestheimer",
    label: "Bryce Westheimer"
  }
];
---

<BaseLayout title="Contact" description="Get in touch for collaboration, research, or speaking opportunities">
  <Header slot="header" />

  <!-- Page Header -->
  <section class="pt-28 pb-12 bg-surface-100 dark:bg-surface-900">
    <div class="container-main">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <h1 class="text-4xl font-bold text-surface-900 dark:text-surface-100">Contact</h1>
        <span class="px-3 py-1 bg-accent-500 text-white text-sm font-semibold rounded-full">
          Open to Opportunities
        </span>
      </div>
      <p class="text-xl text-surface-600 dark:text-surface-400 max-w-3xl">
        I'm actively exploring new positions in industry, national laboratories, and academia.
        Interested in collaboration or career opportunities? I'd love to hear from you.
      </p>
    </div>
  </section>

  <!-- Contact Methods -->
  <section class="py-16">
    <div class="container-main">
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {contactMethods.map((method) => (
          <a 
            href={method.href}
            target={method.icon !== "email" ? "_blank" : undefined}
            rel={method.icon !== "email" ? "noopener noreferrer" : undefined}
            class="card group text-center hover:border-primary-300 dark:hover:border-primary-700 transition-colors"
          >
            <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-primary-100 dark:bg-primary-900 flex items-center justify-center group-hover:bg-primary-200 dark:group-hover:bg-primary-800 transition-colors">
              {method.icon === "email" && (
                <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              )}
              {method.icon === "github" && (
                <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="currentColor" viewBox="0 0 24 24">
                  <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                </svg>
              )}
              {method.icon === "linkedin" && (
                <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              )}
            </div>
            <h3 class="font-semibold text-surface-900 dark:text-surface-100 mb-1">
              {method.title}
            </h3>
            <p class="text-sm text-surface-600 dark:text-surface-400 mb-3">
              {method.description}
            </p>
            <span class="text-sm font-medium text-primary-600 dark:text-primary-400">
              {method.label}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Collaboration Topics -->
  <section class="py-16 bg-surface-100 dark:bg-surface-900">
    <div class="container-main">
      <h2 class="section-title mb-8 text-center">I'm Especially Interested In</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-4xl mx-auto">
        <div class="card text-center p-4">
          <span class="text-sm font-medium text-surface-700 dark:text-surface-300">
            Research Collaborations
          </span>
        </div>
        <div class="card text-center p-4">
          <span class="text-sm font-medium text-surface-700 dark:text-surface-300">
            Speaking Opportunities
          </span>
        </div>
        <div class="card text-center p-4">
          <span class="text-sm font-medium text-surface-700 dark:text-surface-300">
            Open Source Contributions
          </span>
        </div>
        <div class="card text-center p-4">
          <span class="text-sm font-medium text-surface-700 dark:text-surface-300">
            Mentorship & Teaching
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Location -->
  <section class="py-16">
    <div class="container-main text-center">
      <h2 class="section-title mb-4">Based In</h2>
      <p class="text-xl text-surface-600 dark:text-surface-400">
        Vancouver, Washington, USA
      </p>
      <p class="text-surface-500 mt-2">
        Remote for UC Denver (Pacific Time Zone)
      </p>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
