---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestPost = allPosts.length > 0 ? allPosts[0] : null;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

const featuredProjects = [
  {
    title: "autofragment",
    description: "Automatic molecular fragmentation library for fragment-based quantum chemistry calculations. Generates fragment definitions from molecular structures.",
    techs: ["Python", "Fragmentation", "QCSchema"],
    status: "Active" as const,
    href: "https://brycewestheimer.github.io/autofragment-public",
  },
  {
    title: "LibAccInt",
    description: "OpenMP and GPU accelerated integral calculations for quantum chemistry. Provides high-performance one- and two-electron integral evaluation.",
    techs: ["C++", "OpenMP", "CUDA"],
    status: "Active" as const,
    href: "https://brycewestheimer.github.io/libaccint-public",
  },
  {
    title: "Distributed Template Library",
    description: "STL-like ergonomics for distributed and heterogeneous computing, with bindings for C, Fortran, and Python to enable multi-language HPC workflows.",
    techs: ["C++", "MPI", "HPC"],
    status: "Active" as const,
    href: "https://brycewestheimer.github.io/dtl-public",
  },
];
---

<BaseLayout title="Home">
  <Header slot="header" />
  
  <Hero 
    title="Bryce M. Westheimer, PhD"
    subtitle="Scientific Software Developer & Researcher specializing in computational chemistry, high-performance computing, and scientific software engineering."
    highlight="Currently open to new opportunities in industry, national labs, and academia."
    primaryCta={{ text: "View Projects", href: "/projects" }}
    secondaryCta={{ text: "Get in Touch", href: "/contact" }}
  />

  <!-- Featured Projects Section -->
  <section class="py-20">
    <div class="container-main">
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="section-title">Featured Projects</h2>
          <p class="text-surface-600 dark:text-surface-400">
            Selected work in computational chemistry and scientific software
          </p>
        </div>
        <a 
          href="/projects" 
          class="hidden sm:flex items-center gap-1 text-sm font-medium text-primary-600 hover:text-primary-500 dark:text-primary-400 dark:hover:text-primary-300 transition-colors"
        >
          View all projects
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredProjects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>

      <div class="sm:hidden mt-6 text-center">
        <a 
          href="/projects" 
          class="btn btn-secondary"
        >
          View all projects
        </a>
      </div>
    </div>
  </section>

  <!-- Latest Blog Preview -->
  <section class="py-16 bg-surface-100 dark:bg-surface-900">
    <div class="container-main">
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="section-title">Latest Insights</h2>
          <p class="text-surface-600 dark:text-surface-400">
            Technical articles on computational chemistry, software development, and scientific computing
          </p>
        </div>
        <a 
          href="/blog" 
          class="hidden sm:flex items-center gap-1 text-sm font-medium text-primary-600 hover:text-primary-500 dark:text-primary-400 dark:hover:text-primary-300 transition-colors"
        >
          View all articles
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      {latestPost ? (
        <a href={`/blog/${latestPost.slug}`} class="card group block max-w-3xl">
          <div class="flex items-center gap-2 mb-2">
            <time class="text-sm text-surface-500" datetime={latestPost.data.date.toISOString()}>
              {formatDate(latestPost.data.date)}
            </time>
          </div>
          <h3 class="text-xl font-semibold text-surface-900 dark:text-surface-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors mb-2">
            {latestPost.data.title}
          </h3>
          {latestPost.data.description && (
            <p class="text-surface-600 dark:text-surface-400 mb-4">
              {latestPost.data.description}
            </p>
          )}
          {latestPost.data.tags && latestPost.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {latestPost.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ) : (
        <p class="text-surface-600 dark:text-surface-400 text-center py-12">
          No posts yet. Check back soon!
        </p>
      )}

      <div class="sm:hidden mt-6 text-center">
        <a href="/blog" class="btn btn-secondary">
          View all articles
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
