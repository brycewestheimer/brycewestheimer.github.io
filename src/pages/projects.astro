---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Highlighted Projects
const highlightedProjects = [
  {
    title: "autofragment",
    description: "Automatic molecular fragmentation library for fragment-based quantum chemistry calculations. Generates fragment definitions from molecular structures.",
    techs: ["Python", "Fragmentation", "QCSchema"],
    status: "Active" as const,
    href: "https://brycewestheimer.github.io/autofragment-public"
  },
  {
    title: "LibAccInt",
    description: "OpenMP and GPU accelerated integral calculations for quantum chemistry. Provides high-performance one- and two-electron integral evaluation.",
    techs: ["C++", "OpenMP", "CUDA"],
    status: "Active" as const,
    href: "https://brycewestheimer.github.io/libaccint-public"
  },
  {
    title: "Distributed Template Library",
    description: "STL-like ergonomics for distributed and heterogeneous computing, with bindings for C, Fortran, and Python to enable multi-language HPC workflows.",
    techs: ["C++", "MPI", "HPC"],
    status: "Active" as const,
    href: "https://brycewestheimer.github.io/dtl-public"
  }
];

// Open Source Contributions
const openSourceProjects = [
  {
    title: "QCManyBody",
    description: "Fork of MolSSI's QCManyBody library with extended functionality for many-body expansion calculations and fragment-based methods.",
    techs: ["Python", "MBE", "QCSchema"],
    status: "Active" as const,
    github: "https://github.com/brycewestheimer/QCManyBody"
  },
  {
    title: "GAMESS",
    description: "Core contributor to the GAMESS fragmentation roadmap. Current work targets MAP enablement, rigorous covalent fragment treatments, and accelerator portability.",
    techs: ["Fortran", "C", "CUDA", "MPI"],
    status: "Active" as const,
    href: "https://www.msg.chem.iastate.edu/gamess/"
  }
];

// Scientific Computing
const scientificProjects = [
  {
    title: "RCChem",
    description: "A modular quantum chemistry package written in Rust, featuring DFT calculations, integral transforms, and post-SCF methods. Designed for performance and correctness.",
    techs: ["Rust", "DFT", "HPC"],
    status: "Development" as const,
    github: "https://github.com/brycewestheimer/rcchem"
  },
  {
    title: "QCBase",
    description: "Foundational library for quantum chemistry applications, providing core data structures, algorithms, and utilities for electronic structure calculations.",
    techs: ["C++", "Python", "CMake"],
    status: "Development" as const,
    github: "https://github.com/brycewestheimer/QCBase"
  }
];

// AI/ML
const aimlProjects = [
  {
    title: "Equivariant Residual GNNs",
    description: "Graph neural network architecture with equivariant residual connections for molecular property prediction. Leverages geometric deep learning for chemical systems.",
    techs: ["PyTorch", "PyG", "E(3)-Equivariant"],
    status: "Development" as const,
    github: "#"
  },
  {
    title: "Reference Anchored Residual NNs",
    description: "Neural network architecture using reference-anchored residual learning for improved transferability in molecular simulations and property prediction.",
    techs: ["PyTorch", "ML", "Chemistry"],
    status: "Development" as const,
    github: "#"
  }
];

// Software Engineering
const softwareProjects = [
  {
    title: "Personal Website",
    description: "This portfolio website, built with Astro and Tailwind CSS. Features dark mode, responsive design, blog/tutorial content collections, and CI/CD deployment.",
    techs: ["Astro", "Tailwind CSS", "GitHub Actions"],
    status: "Active" as const,
    github: "https://github.com/brycewestheimer/brycewestheimer.github.io"
  }
];

// Data Analysis
const dataProjects = [
  {
    title: "Coming Soon",
    description: "Data analysis and visualization project currently in development. Check back for updates on interactive dashboards and scientific data tools.",
    techs: ["Python", "Visualization"],
    status: "Planned" as const,
    github: "#"
  }
];
---

<BaseLayout title="Projects" description="A showcase of computational chemistry, AI/ML, and software development projects">
  <Header slot="header" />

  <!-- Page Header -->
  <section class="pt-28 pb-12 bg-surface-100 dark:bg-surface-900">
    <div class="container-main">
      <h1 class="text-4xl font-bold text-surface-900 dark:text-surface-100 mb-4">Projects</h1>
      <p class="text-xl text-surface-600 dark:text-surface-400 max-w-3xl">
        A showcase of work spanning scientific computing, AI/ML, open source contributions, 
        and software engineering - from research prototypes to production-ready tools.
      </p>
    </div>
  </section>

  <!-- Highlighted Projects -->
  <section class="py-16">
    <div class="container-main">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-lg bg-accent-100 dark:bg-accent-900 flex items-center justify-center">
          <svg class="w-5 h-5 text-accent-600 dark:text-accent-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </div>
        <h2 class="section-title">Highlighted Projects</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {highlightedProjects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </div>
  </section>

  <!-- Open Source Contributions -->
  <section class="py-16">
    <div class="container-main">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-lg bg-primary-100 dark:bg-primary-900 flex items-center justify-center">
          <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
        <h2 class="section-title">Open Source Contributions</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {openSourceProjects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </div>
  </section>

  <!-- Scientific Computing -->
  <section class="py-16 bg-surface-100 dark:bg-surface-900">
    <div class="container-main">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-lg bg-accent-100 dark:bg-accent-900 flex items-center justify-center">
          <svg class="w-5 h-5 text-accent-600 dark:text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
          </svg>
        </div>
        <h2 class="section-title">Scientific Computing</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {scientificProjects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </div>
  </section>

  <!-- AI/ML -->
  <section class="py-16">
    <div class="container-main">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-lg bg-purple-100 dark:bg-purple-900 flex items-center justify-center">
          <svg class="w-5 h-5 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
        </div>
        <h2 class="section-title">AI / Machine Learning</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {aimlProjects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </div>
  </section>

  <!-- Software Engineering -->
  <section class="py-16 bg-surface-100 dark:bg-surface-900">
    <div class="container-main">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-lg bg-blue-100 dark:bg-blue-900 flex items-center justify-center">
          <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
        </div>
        <h2 class="section-title">Software Engineering</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {softwareProjects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </div>
  </section>

  <!-- Data Analysis -->
  <section class="py-16">
    <div class="container-main">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-lg bg-green-100 dark:bg-green-900 flex items-center justify-center">
          <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </div>
        <h2 class="section-title">Data Analysis & Visualization</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {dataProjects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </div>
  </section>

  <!-- Get Involved -->
  <section class="py-16 bg-primary-600 dark:bg-primary-800">
    <div class="container-main text-center">
      <h2 class="text-2xl font-bold text-white mb-4">Want to Collaborate?</h2>
      <p class="text-primary-100 mb-6 max-w-xl mx-auto">
        Check open issues in each repository or reach out to discuss research and development opportunities.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="https://github.com/brycewestheimer" target="_blank" rel="noopener noreferrer" class="btn btn-accent">
          View on GitHub
        </a>
        <a href="/contact" class="btn bg-white/10 text-white border-2 border-white/30 hover:bg-white/20">
          Contact Me
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
